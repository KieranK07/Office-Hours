# Environment Configuration
# Copy this file to .env and update with your values

# Security Settings (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]

# Optional: Database Configuration
# DATABASE_URL=sqlite:///./office_hours.db
# DATABASE_URL=postgresql://user:password@localhost/office_hours

# System Configuration
MAX_SEVERITY=5
MIN_SEVERITY=1

# API Configuration
API_TITLE=Office Hours Triage API
API_VERSION=1.0.0
API_DESCRIPTION=Secure FastAPI server for managing student office hours queues
